{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/livewire-starter-kit",
    "type": "project",
    "description": "The official Laravel starter kit for Livewire.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "clickbar/laravel-magellan": "^2.0",
        "fivefilters/readability.php": "^3.3",
        "guzzlehttp/guzzle": "^7.10",
        "html2text/html2text": "^4.3",
        "icehouse-ventures/laravel-chartjs": "^4.2",
        "intervention/image": "^3.11",
        "jenssegers/agent": "^2.6",
        "laravel-notification-channels/apn": "*",
        "laravel-notification-channels/webpush": "^10.3",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.30.3",
        "laravel/mcp": "^0.5.9",
        "laravel/octane": "*",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.30",
        "livewire/livewire": "^3.6",
        "livewire/volt": "^1.7",
        "openai-php/laravel": "^0.18.0",
        "owenvoke/blade-fontawesome": "^2.9",
        "pgvector/pgvector": "^0.2.2",
        "pragmarx/version": "dev-master",
        "predis/predis": "^3.2",
        "revolution/laravel-bluesky": "^1.1",
        "robsontenorio/mary": "dev-main",
        "sentry/sentry-laravel": "^4.9",
        "smalot/pdfparser": "^2.12",
        "socialiteproviders/authelia": "^4.0",
        "spatie/laravel-activitylog": "^4",
        "spatie/laravel-medialibrary": "^11.17",
        "spatie/laravel-tags": "^4.10",
        "symfony/emoji": "^7.3",
        "willscottuk/monzo-php": "dev-master",
        "wire-elements/pro": "^4.0",
        "zbateson/mail-mime-parser": "^3.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.20.0",
        "deployer/deployer": "^7.5",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^1.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.44",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/php-code-coverage": "^14",
        "phpunit/php-file-iterator": "^7",
        "phpunit/php-invoker": "^7.0.0",
        "phpunit/php-text-template": "^6.0",
        "phpunit/php-timer": "^9",
        "phpunit/phpunit": "^13.0.0",
        "ryoluo/sail-ssl": "^1.4",
        "sebastian/cli-parser": "^5.0.0",
        "sebastian/comparator": "^8.1.2",
        "sebastian/complexity": "^6.0",
        "sebastian/diff": "^8.1",
        "sebastian/environment": "^9.1",
        "sebastian/exporter": "^8.0",
        "sebastian/global-state": "^9.0.0",
        "sebastian/lines-of-code": "^5.0",
        "sebastian/object-enumerator": "^8.0.0",
        "sebastian/object-reflector": "^6.0",
        "sebastian/recursion-context": "^8.0",
        "sebastian/type": "^7.0.0",
        "sebastian/version": "^7.0",
        "theseer/tokenizer": "^2.0.1",
        "tightenco/duster": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php",
            "app/Support/SentryAiHelpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan sentry:publish --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan horizon\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,horizon,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.1"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:cronxco/graby.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:cronxco/mary.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:willscottuk/monzo-php.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:cronxco/plaid-sdk-php.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:cronxco/version.git"
        },
        {
            "name": "wire-elements/pro",
            "type": "composer",
            "url": "https://wire-elements-pro.composer.sh",
            "only": [
                "wire-elements/*"
            ]
        },
        {
            "type": "vcs",
            "url": "git@github.com:willscottuk/laravel-supabase-auth.git"
        }
    ]
}
