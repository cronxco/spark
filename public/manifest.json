{
    "$schema": "https://json.schemastore.org/web-manifest-combined.json",
    "name": "Spark",
    "short_name": "Spark",
    "start_url": "/dashboard",
    "display": "standalone",
    "background_color": "#010E19",
    "theme_color": "#010E19",
    "description": "Synaptic aggregation, analysis and action.",
    "orientation": "portrait-primary",
    "icons": [
        {
            "src": "/favicon-32.png",
            "sizes": "32x32",
            "type": "image/png"
        },
        {
            "src": "/favicon-72.png",
            "sizes": "72x72",
            "type": "image/png"
        },
        {
            "src": "/favicon-96.png",
            "sizes": "96x96",
            "type": "image/png"
        },
        {
            "src": "/favicon-144.png",
            "sizes": "144x144",
            "type": "image/png"
        },
        {
            "src": "/favicon-160.png",
            "sizes": "160x160",
            "type": "image/png"
        },
        {
            "src": "/favicon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/apple-touch-icon.png",
            "sizes": "180x180",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    "categories": ["productivity", "lifestyle"],
    "prefer_related_applications": false
}
